{
  "name": "ticketing-backend",
  "version": "1.0.0",
  "private": true,
  "description": "YouTicket API (Node + Express + Prisma + Postgres)",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build": "tsc",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:clean": "ts-node prisma/seed.ts --clean-only",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "esbuild": "0.25.12"
  }
}
