PORT=8080
HOST=0.0.0.0

# Abilita le richieste da frontend specifico (se lasciato vuoto usa localhost:4200)
CORS_ORIGIN=*

# Stringa di connessione a PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ticketdb

# Secret per firmare i token JWT (obbligatorio) - genera una stringa lunga e casuale
JWT_SECRET=