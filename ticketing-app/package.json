{
  "name": "ticketing-app",
  "version": "1.0.0",
  "private": true,
  "description": "YouTicket (Node + Express + EJS + Prisma + Postgres)",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "build": "tsc",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:clean": "ts-node prisma/seed.ts --clean-only"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^2.0.1",
    "pg": "^8.22.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.20.0",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "esbuild": "0.25.12"
  }
}
